<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         testdox="true">
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
    <coverage>
        <report>
            <html outputDirectory="coverage"/>
            <text outputFile="php://stdout"/>
        </report>
    </coverage>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="ZATCA_ENVIRONMENT" value="sandbox"/>
        <env name="ZATCA_SANDBOX_USERNAME" value="test_user"/>
        <env name="ZATCA_SANDBOX_PASSWORD" value="test_pass"/>
        <env name="ZATCA_VAT_NUMBER" value="300000000000003"/>
        <env name="ZATCA_SELLER_NAME_EN" value="Test Company"/>
        <env name="ZATCA_CSR_ORGANIZATION" value="Test Company"/>
        <env name="ZATCA_CSR_COMMON_NAME" value="Test Company"/>
    </php>
</phpunit>
