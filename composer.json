{
    "name": "saudizatca/laravel-zatca",
    "description": "Complete Laravel package for ZATCA (Saudi Arabia) E-Invoicing Phase 2 integration - Supports Sandbox, Simulation, and Production environments",
    "type": "library",
    "keywords": ["zatca", "fatoora", "e-invoicing", "saudi-arabia", "laravel", "phase-2", "tax", "vat"],
    "license": "MIT",
    "authors": [
        {
            "name": "Saudi ZATCA Integration Team",
            "email": "dev@saudizatca.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "ext-openssl": "*",
        "ext-dom": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-gmp": "*",
        "ext-xmlwriter": "*",
        "ext-curl": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "SaudiZATCA\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SaudiZATCA\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SaudiZATCA\\ZatcaServiceProvider"
            ],
            "aliases": {
                "Zatca": "SaudiZATCA\\Facades\\Zatca"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit --no-coverage",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse src tests --level=8",
        "phpcs": "phpcs src tests --standard=PSR12 --exclude=PSR1.Methods.CamelCapsMethodName,Generic.Files.LineLength",
        "phpcbf": "phpcbf src tests --standard=PSR12 --exclude=PSR1.Methods.CamelCapsMethodName,Generic.Files.LineLength"
    }
}
